# Copy to .env and fill in. All variables are prefixed FCI_.

# Direct-customer API keys (comma separated). Generate long random strings.
FCI_API_KEYS=replace-with-a-long-random-key

# From RapidAPI provider dashboard once you list the API (leave blank until then).
FCI_RAPIDAPI_PROXY_SECRET=

# Free key: sam.gov -> sign in -> Account Details -> API Key.
# Needed only for /v1/opportunities/*; all other endpoints work without it.
FCI_SAM_API_KEY=

# true = no auth (local dev only). NEVER in production.
FCI_DEMO_MODE=false

FCI_RATE_LIMIT_PER_MINUTE=120
