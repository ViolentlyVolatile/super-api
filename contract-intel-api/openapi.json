{
  "openapi": "3.1.0",
  "info": {
    "title": "Federal Contract Intelligence API",
    "description": "\nSearch **$700B+/year** of US federal contract activity through one clean JSON API.\n\n| Capability | Endpoint |\n|---|---|\n| Contract award search | `POST /v1/awards/search` |\n| Full award detail | `GET /v1/awards/{internal_id}` |\n| Live solicitations | `GET /v1/opportunities/search` |\n| Spending analytics | `POST /v1/analytics/spending` |\n| **Recompete Radar** \u2014 contracts expiring soon | `POST /v1/recompetes/search` |\n\nAuthenticate with the `X-API-Key` header (or subscribe via RapidAPI).\nAll underlying data is public-domain US government data.\n",
    "contact": {
      "name": "NexMath",
      "email": "karan@nexmath.com"
    },
    "license": {
      "name": "Data: US public domain; Service: commercial"
    },
    "version": "1.0.0"
  },
  "paths": {
    "/v1/awards/search": {
      "post": {
        "tags": [
          "Awards"
        ],
        "summary": "Search federal contract awards",
        "description": "Search prime contract awards government-wide. Filter by keyword, NAICS,\nPSC, agency, vendor, action-date window, and award amount.",
        "operationId": "search_awards_v1_awards_search_post",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          },
          {
            "name": "x-rapidapi-proxy-secret",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Rapidapi-Proxy-Secret"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AwardSearchRequest"
              },
              "example": {
                "keywords": [
                  "cybersecurity"
                ],
                "naics_codes": [
                  "336413"
                ],
                "agency": "Department of Defense",
                "start_date": "2018-01-01",
                "sort": "Award Amount",
                "order": "desc",
                "limit": 25,
                "page": 1
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Paged list of matching prime contract awards, largest first.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Paged"
                },
                "example": {
                  "page": 1,
                  "limit": 2,
                  "has_next": true,
                  "results": [
                    {
                      "award_id": "FA862118F6251",
                      "internal_id": "CONT_AWD_FA862118F6251_9700_FA862115D6276_9700",
                      "recipient_name": "LOCKHEED MARTIN CORPORATION",
                      "description": "IGF::OT::IGF  AFSOC ACTS AWARD OF CONTRACT FOR CLS, ENGINEERING, INSTRUCTION, CYBERSECURITY, DMO",
                      "amount": 632998084.56,
                      "start_date": "2018-02-08",
                      "end_date": "2027-01-31",
                      "awarding_agency": "Department of Defense",
                      "awarding_sub_agency": "Department of the Air Force",
                      "naics": "336413",
                      "psc": "J069"
                    },
                    {
                      "award_id": "HQ085722F8003",
                      "internal_id": "CONT_AWD_HQ085722F8003_9700_HQ079617D0001_9700",
                      "recipient_name": "AMENTUM TECHNOLOGY, INC.",
                      "description": "DELIVER INFORMATION MANAGEMENT AND IT SERVICES TO MDA FOR UNCLASSIFIED AND CLASSIFIED NETWORKS. PERFORM BREAK-FIX, MAINTENANCE AND CYBERSECURITY OF CIO MANAGED NETWORKS WITHIN MDA.",
                      "amount": 524055138.18,
                      "start_date": "2022-09-05",
                      "end_date": "2025-09-01",
                      "awarding_agency": "Department of Defense",
                      "awarding_sub_agency": "Missile Defense Agency",
                      "naics": "541712",
                      "psc": "AC23"
                    }
                  ]
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/awards/{internal_id}": {
      "get": {
        "tags": [
          "Awards"
        ],
        "summary": "Full award detail",
        "description": "Full USAspending record for one award. Use the `internal_id` returned by\n/v1/awards/search (e.g. `CONT_AWD_...`).",
        "operationId": "award_detail_v1_awards__internal_id__get",
        "parameters": [
          {
            "name": "internal_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Internal Id",
              "example": "CONT_AWD_FA862118F6251_9700_FA862115D6276_9700"
            },
            "example": "CONT_AWD_FA862118F6251_9700_FA862115D6276_9700"
          },
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
