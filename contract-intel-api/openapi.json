{
  "openapi": "3.1.0",
  "info": {
    "title": "Federal Contract Intelligence API",
    "description": "\nSearch **$700B+/year** of US federal contract activity through one clean JSON API.\n\n| Capability | Endpoint |\n|---|---|\n| Contract award search | `POST /v1/awards/search` |\n| Full award detail | `GET /v1/awards/{internal_id}` |\n| Live solicitations | `GET /v1/opportunities/search` |\n| Spending analytics | `POST /v1/analytics/spending` |\n| **Recompete Radar** \u2014 contracts expiring soon | `POST /v1/recompetes/search` |\n\nAuthenticate with the `X-API-Key` header (or subscribe via RapidAPI).\nAll underlying data is public-domain US government data.\n",
    "contact": {
      "name": "NexMath",
      "email": "karan@nexmath.com"
    },
    "license": {
      "name": "Data: US public domain; Service: commercial"
    },
    "version": "1.0.0"
  },
  "paths": {
    "/v1/awards/search": {
      "post": {
        "tags": [
          "Awards"
        ],
        "summary": "Search federal contract awards",
        "description": "Search prime contract awards government-wide. Filter by keyword, NAICS,\nPSC, agency, vendor, action-date window, and award amount.",
        "operationId": "search_awards_v1_awards_search_post",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          },
          {
            "name": "x-rapidapi-proxy-secret",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Rapidapi-Proxy-Secret"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AwardSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Paged"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/awards/{internal_id}": {
      "get": {
        "tags": [
          "Awards"
        ],
        "summary": "Full award detail",
        "description": "Full USAspending record for one award. Use the `internal_id` returned by\n/v1/awards/search (e.g. `CONT_AWD_...`).",
        "operationId": "award_detail_v1_awards__internal_id__get",
        "parameters": [
          {
            "name": "internal_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Internal Id"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          },
          {
            "name": "x-rapidapi-proxy-secret",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Rapidapi-Proxy-Secret"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "title": "Response Award Detail V1 Awards  Internal Id  Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/recompetes/search": {
      "post": {
        "tags": [
          "Recompete Radar"
        ],
        "summary": "Find contracts expiring soon (likely recompetes)",
        "operationId": "search_recompetes_v1_recompetes_search_post",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          },
          {
            "name": "x-rapidapi-proxy-secret",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Rapidapi-Proxy-Secret"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecompeteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Paged"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/analytics/spending": {
      "post": {
        "tags": [
          "Analytics"
        ],
        "summary": "Spending totals grouped by a dimension",
        "description": "Who gets the money? Group federal contract spending by `naics`, `psc`,\n`awarding_agency`, or `recipient` -- optionally scoped by keyword, NAICS,\nagency, and fiscal year. Ideal for market sizing and competitor analysis.",
        "operationId": "spending_breakdown_v1_analytics_spending_post",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          },
          {
            "name": "x-rapidapi-proxy-secret",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Rapidapi-Proxy-Secret"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SpendingBreakdownRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Paged"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/opportunities/search": {
      "get": {
        "tags": [
          "Opportunities"
        ],
        "summary": "Search live solicitations",
        "operationId": "search_opportunities_v1_opportunities_search_get",
        "parameters": [
          {
            "name": "keywords",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Free-text title search",
              "title": "Keywords"
            },
            "description": "Free-text title search"
          },
          {
            "name": "naics",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "NAICS code, e.g. 336411",
              "title": "Naics"
            },
            "description": "NAICS code, e.g. 336411"
          },
          {
            "name": "notice_type",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "p=Presolicitation, o=Solicitation, k=Combined Synopsis, r=Sources Sought, s=Special Notice",
              "title": "Notice Type"
            },
            "description": "p=Presolicitation, o=Solicitation, k=Combined Synopsis, r=Sources Sought, s=Special Notice"
          },
          {
            "name": "set_aside",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "e.g. SBA, 8A, WOSB, SDVOSBC",
              "title": "Set Aside"
            },
            "description": "e.g. SBA, 8A, WOSB, SDVOSBC"
          },
          {
            "name": "days_back",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 365,
              "minimum": 1,
              "description": "How many days of postings to search",
              "default": 30,
              "title": "Days Back"
            },
            "description": "How many days of postings to search"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "default": 25,
              "title": "Limit"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "title": "Offset"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          },
          {
            "name": "x-rapidapi-proxy-secret",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Rapidapi-Proxy-Secret"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Paged"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Meta"
        ],
        "summary": "Liveness probe (no auth)",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AwardSearchRequest": {
        "properties": {
          "keywords": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Keywords",
            "description": "Free-text keywords, e.g. ['radar', 'maintenance']"
          },
          "naics_codes": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Naics Codes",
            "description": "NAICS codes, e.g. ['336411']"
          },
          "psc_codes": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Psc Codes",
            "description": "Product/Service Codes, e.g. ['1560']"
          },
          "agency": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Agency",
            "description": "Awarding top-tier agency name, e.g. 'Department of Defense'"
          },
          "recipient_search_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Recipient Search Text",
            "description": "Recipient (vendor) name to match"
          },
          "start_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "Start Date",
            "description": "Action date window start (YYYY-MM-DD)"
          },
          "end_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "End Date",
            "description": "Action date window end (YYYY-MM-DD)"
          },
          "min_amount": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Min Amount"
          },
          "max_amount": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Amount"
          },
          "sort": {
            "type": "string",
            "title": "Sort",
            "description": "One of: 'Award Amount', 'Start Date', 'End Date', 'Recipient Name'",
            "default": "Award Amount"
          },
          "order": {
            "type": "string",
            "pattern": "^(asc|desc)$",
            "title": "Order",
            "default": "desc"
          },
          "limit": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 1.0,
            "title": "Limit",
            "default": 25
          },
          "page": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Page",
            "default": 1
          }
        },
        "type": "object",
        "title": "AwardSearchRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "Paged": {
        "properties": {
          "page": {
            "type": "integer",
            "title": "Page"
          },
          "limit": {
            "type": "integer",
            "title": "Limit"
          },
          "has_next": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Has Next"
          },
          "results": {
            "items": {},
            "type": "array",
            "title": "Results"
          }
        },
        "type": "object",
        "required": [
          "page",
          "limit",
          "results"
        ],
        "title": "Paged"
      },
      "RecompeteRequest": {
        "properties": {
          "months_ahead": {
            "type": "integer",
            "maximum": 36.0,
            "minimum": 1.0,
            "title": "Months Ahead",
            "description": "Window size from today, in months",
            "default": 12
          },
          "naics_codes": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Naics Codes"
          },
          "psc_codes": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Psc Codes"
          },
          "agency": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Agency",
            "description": "Awarding top-tier agency name"
          },
          "keywords": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Keywords"
          },
          "min_amount": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Min Amount",
            "description": "Only include awards >= this obligated amount"
          },
          "limit": {
            "type": "integer",
            "maximum": 200.0,
            "minimum": 1.0,
            "title": "Limit",
            "default": 50
          }
        },
        "type": "object",
        "title": "RecompeteRequest",
        "description": "Find contracts whose period of performance ends inside a window --\ni.e. predictable upcoming re-competitions."
      },
      "SpendingBreakdownRequest": {
        "properties": {
          "dimension": {
            "type": "string",
            "pattern": "^(naics|psc|awarding_agency|recipient)$",
            "title": "Dimension"
          },
          "keywords": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Keywords"
          },
          "naics_codes": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Naics Codes"
          },
          "agency": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Agency"
          },
          "fiscal_year": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 2030.0,
                "minimum": 2008.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Fiscal Year"
          },
          "limit": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 1.0,
            "title": "Limit",
            "default": 25
          },
          "page": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Page",
            "default": 1
          }
        },
        "type": "object",
        "required": [
          "dimension"
        ],
        "title": "SpendingBreakdownRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}