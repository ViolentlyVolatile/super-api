  "components": {
    "schemas": {
      "AwardSearchRequest": {
        "properties": {
          "keywords": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Keywords",
            "description": "Free-text keywords, e.g. ['radar', 'maintenance']"
          },
          "naics_codes": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Naics Codes",
            "description": "NAICS codes, e.g. ['336411']"
          },
          "psc_codes": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Psc Codes",
            "description": "Product/Service Codes, e.g. ['1560']"
          },
          "agency": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Agency",
            "description": "Awarding top-tier agency name, e.g. 'Department of Defense'"
          },
          "recipient_search_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Recipient Search Text",
            "description": "Recipient (vendor) name to match"
          },
          "start_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "Start Date",
            "description": "Action date window start (YYYY-MM-DD)"
          },
          "end_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
