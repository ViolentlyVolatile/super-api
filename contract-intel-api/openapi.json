    "/v1/opportunities/search": {
      "get": {
        "tags": [
          "Opportunities"
        ],
        "summary": "Search live solicitations",
        "description": "Search open federal solicitations sourced from SAM.gov. Filter by keyword, NAICS, notice type, set-aside, and how many days back to look. Every result links to the official SAM.gov notice via `ui_link`.",
        "operationId": "search_opportunities_v1_opportunities_search_get",
        "parameters": [
          {
            "name": "keywords",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Free-text title search",
              "title": "Keywords",
              "example": "cyber"
            },
            "description": "Free-text title search",
            "example": "cyber"
          },
          {
            "name": "naics",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
